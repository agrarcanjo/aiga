{
  "name": "aiga",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo do assistente desktop AIGA",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "corepack pnpm --filter @aiga/desktop dev",
    "build": "corepack pnpm --filter @aiga/desktop build",
    "lint": "corepack pnpm --filter @aiga/desktop lint",
    "typecheck": "corepack pnpm --filter @aiga/desktop typecheck",
    "test": "corepack pnpm --filter @aiga/desktop test",
    "test:e2e": "corepack pnpm --filter @aiga/desktop test:e2e",
    "pack:win": "corepack pnpm --filter @aiga/desktop pack:win",
    "dist:win": "corepack pnpm --filter @aiga/desktop dist:win",
    "beta:gates": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/beta/run-beta-gates.ps1",
    "beta:triage:today": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/beta/start-triage-day.ps1",
    "beta:publish:check": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/beta/publish-checklist.ps1"
  }
}
