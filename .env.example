# Modo de execução
NODE_ENV=development

# Observabilidade
DESKTOP_LOG_LEVEL=info

# Modelo Gemini (opcional)
GEMINI_MODEL=gemini-2.0-flash

# Feature flags por ambiente (opcional)
# cloud | local | hybrid
FEATURE_PROVIDER_MODE=cloud
# true | false
FEATURE_LOCAL_PROVIDER_ENABLED=false
# true | false
FEATURE_FORCE_LOCAL_ONLY=false
# off | safe | strict
FEATURE_STEALTH_HARDENING=safe
